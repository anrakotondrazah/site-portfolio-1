---
import SectionLabel from "~/components/shared/SectionLabel.astro";
import CyberButton from "~/components/shared/CyberButton.astro";
---

<div
  class="relative z-20 text-center px-6 max-w-4xl mx-auto"
  data-gsap="hero-content"
>
  <div data-gsap="hero-label">
    <SectionLabel index="01" label="HERO" align="center" />
  </div>

  <!-- Pre-headline -->
  <p
    class="font-mono text-mono-xs tracking-[0.15em] text-cyber-text-dim mb-6"
    data-gsap="hero-label"
  >
    WELCOME TO THE NEXT GENERATION OF VISUAL CONTENT
  </p>

  <!-- Main Headline -->
  <h1 class="font-display text-display-xl mb-4" data-gsap="hero-title">
    <span class="text-white">AI CREATES.</span><br />
    <span class="text-gradient-cyber">YOU PROFIT.</span>
  </h1>

  <!-- Sub-headline -->
  <p
    class="font-mono text-sm text-cyber-text-secondary max-w-2xl mx-auto mb-4"
    data-gsap="hero-subtitle"
  >
    Studio-quality images, cinematic videos & immersive animations &mdash;
    generated by AI, crafted by a developer who&rsquo;s already living in 2030.
  </p>

  <!-- Description -->
  <p
    class="font-mono text-mono-sm text-cyber-text-dim max-w-xl mx-auto mb-8"
    data-gsap="hero-desc"
  >
    AI-generated images, videos & visual content for brands that refuse to be
    ordinary &mdash; delivered in 24 hours by a developer who masters
    tomorrow&rsquo;s tools.
  </p>

  <!-- CTAs -->
  <div
    class="flex flex-col sm:flex-row gap-4 justify-center items-center"
    data-gsap="hero-cta"
  >
    <CyberButton href="#demo" variant="primary">
      Generate a Visual &mdash; It&rsquo;s Free
    </CyberButton>
    <CyberButton href="#gallery" variant="secondary">
      See the Gallery &darr;
    </CyberButton>
  </div>

  <!-- Trust line -->
  <p
    class="font-mono text-mono-xs text-cyber-text-dim/50 mt-6"
    data-gsap="hero-cta"
  >
    No account needed. No credit card. Just describe what you want.
  </p>

  <!-- Scroll indicator -->
  <div
    class="absolute bottom-8 left-1/2 -translate-x-1/2 z-30"
    data-gsap="hero-scroll"
  >
    <div class="flex flex-col items-center gap-2 animate-bounce">
      <span class="font-mono text-mono-xs text-cyber-cyan/40 tracking-widest"
        >SCROLL TO EXPLORE</span
      >
      <svg
        width="16"
        height="16"
        viewBox="0 0 16 16"
        fill="none"
        class="text-cyber-cyan/40"
      >
        <path
          d="M4 6L8 10L12 6"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </div>
  </div>
</div>
