---
import NoiseOverlay from "~/components/shared/NoiseOverlay.astro";
import CustomCursor from "~/components/shared/CustomCursor.tsx";
import Navigation from "~/components/shared/Navigation.astro";
import Footer from "~/components/shared/Footer.astro";
import { SITE } from "~/config";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = SITE.title,
  description = SITE.description,
  ogImage = "/og-image.jpg",
} = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://generativelanguage.googleapis.com" />

    <title>{title}</title>
  </head>
  <body
    class="bg-cyber-dark text-cyber-text-primary overflow-x-hidden font-mono"
  >
    <NoiseOverlay />
    <CustomCursor client:only="react" />
    <Navigation />

    <main>
      <slot />
    </main>

    <Footer />

    <script>
      document.documentElement.classList.add("js-loaded");
    </script>
  </body>
</html>
